<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Create HR Account</title>

    <link rel="stylesheet" href="/css/hr-setup.css">

</head>

<body>

    <div class="container">

        <div class="setup-card">

            <h1>Employee Management System</h1>

            <h2>Create HR Account</h2>

            <% if (error) { %>

                <div class="error">
                    <%= error %>
                </div>

            <% } %>

            <form action="/hr/setup" method="POST">

                <div class="form-group">

                    <label>Full Name</label>

                    <input
                        type="text"
                        name="name"
                        placeholder="Enter Full Name"
                        required>

                </div>

                <div class="form-group">

                    <label>Username</label>

                    <input
                        type="text"
                        name="username"
                        placeholder="Enter Username"
                        required>

                </div>

                <div class="form-group">

                    <label>Email</label>

                    <input
                        type="email"
                        name="email"
                        placeholder="Enter Email"
                        required>

                </div>

                <div class="form-group">

                    <label>Password</label>

                    <input
                        type="password"
                        name="password"
                        placeholder="Enter Password"
                        required>

                </div>

                <div class="form-group">

                    <label>Confirm Password</label>

                    <input
                        type="password"
                        name="confirmPassword"
                        placeholder="Confirm Password"
                        required>

                </div>

                <button type="submit">

                    Create HR Account

                </button>

            </form>

            <p>

                Already have an account?

                <a href="/hr/login">

                    Login

                </a>

            </p>

        </div>

    </div>

</body>

</html>