<%- include("../partials/head", { title: title }) %>

<link rel="stylesheet" href="/css/employee.css">

<div class="dashboard-container">

    <%- include("../partials/sidebar") %>

    <div class="main-content">

        <%- include("../partials/header", { user: user }) %>

        <div class="page-content">

            <div class="page-header">

                <div>

                    <h1>Employees</h1>

                    <p>Manage all employees in the Employee Management System.</p>

                </div>

                <div class="page-actions">

                    <a
                        href="/hr/dashboard"
                        class="btn btn-secondary"
                    >
                        Back to Dashboard
                    </a>

                    <a
                        href="/hr/employees/create"
                        class="btn btn-success"
                    >
                        Create Employee
                    </a>

                </div>

            </div>

            <!-- ==========================================
                 EMPLOYEE STATISTICS
            ========================================== -->

            <div class="stats-grid">

                <div class="stat-card">

                    <h4>Total Employees</h4>

                    <h2>

                        <%= stats.totalEmployees %>

                    </h2>

                </div>

                <div class="stat-card">

                    <h4>Active Employees</h4>

                    <h2>

                        <%= stats.activeEmployees %>

                    </h2>

                </div>

                <div class="stat-card">

                    <h4>Inactive Employees</h4>

                    <h2>

                        <%= stats.inactiveEmployees %>

                    </h2>

                </div>

                <div class="stat-card">

                    <h4>New Today</h4>

                    <h2>

                        <%= stats.newEmployees %>

                    </h2>

                </div>

            </div>

            <% if (employees.length === 0) { %>

                <div class="dashboard-box">

                    <h2>No Employees Found</h2>

                    <p>No employee records have been created yet.</p>

                </div>

            <% } else { %>

                <table class="employee-table">

                    <thead>

                        <tr>

                            <th>S.No</th>
                            <th>Employee ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Department</th>
                            <th>Designation</th>
                            <th>Status</th>
                            <th>Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% employees.forEach(function(employee,index){ %>

                            <tr>

                                <td><%= index + 1 %></td>

                                <td><%= employee.employeeId %></td>

                                <td><%= employee.name %></td>

                                <td><%= employee.email %></td>

                                <td><%= employee.phone %></td>

                                <td><%= employee.department %></td>

                                <td><%= employee.designation %></td>

                                <td>

                                    <span class="<%= employee.status === 'Active' ? 'status-active' : 'status-inactive' %>">

                                        <%= employee.status %>

                                    </span>

                                </td>

                                <td>

                                    <a
                                        href="/hr/employees/edit/<%= employee._id %>"
                                        class="btn btn-warning"
                                    >
                                        Edit
                                    </a>

                                    <button
                                        type="button"
                                        class="btn btn-danger"
                                        onclick="openDeleteModal('<%= employee._id %>','<%= employee.name %>')"
                                    >
                                        Delete
                                    </button>

                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            <% } %>

        </div>

    </div>

</div>

<!-- ==================================================
DELETE EMPLOYEE MODAL
================================================== -->

<div id="deleteModal" class="modal-overlay">

    <div class="modal-box">

        <h2>Delete Employee</h2>

        <p>Are you sure you want to delete</p>

        <h3 id="deleteEmployeeName"></h3>

        <p class="warning-text">

            This action cannot be undone.

        </p>

        <div class="modal-buttons">

            <button
                type="button"
                class="btn btn-secondary"
                onclick="closeDeleteModal()"
            >

                No

            </button>

            <a
                id="confirmDeleteBtn"
                class="btn btn-danger"
            >

                Yes, Delete

            </a>

        </div>

    </div>

</div>

<script src="/js/employee.js"></script>

<%- include("../partials/footer") %>