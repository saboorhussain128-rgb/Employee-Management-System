<%- include("../partials/head", { title: title }) %>

<link rel="stylesheet" href="/css/employee.css">

<div class="dashboard-container">

    <%- include("../partials/sidebar") %>

    <div class="main-content">

        <%- include("../partials/header", { user: user }) %>

        <div class="page-content">

            <div class="page-header">

                <div>

                    <h1>Employees</h1>

                    <p>Manage all employees in the Employee Management System.</p>

                </div>

                <div class="page-actions">

                    <a href="/hr/dashboard" class="btn btn-secondary">

                        Back to Dashboard

                    </a>

                    <a href="/hr/employees/create" class="btn btn-success">

                        Create Employee

                    </a>

                </div>

            </div>

            <% if (employees.length === 0) { %>

                <div class="dashboard-box">

                    <h2>No Employees Found</h2>

                    <p>No employee records have been created yet.</p>

                </div>

            <% } else { %>

                <table class="employee-table">

                    <thead>

                        <tr>

                            <th>S.No</th>

                            <th>Employee ID</th>

                            <th>Name</th>

                            <th>Email</th>

                            <th>Phone</th>

                            <th>Department</th>

                            <th>Designation</th>

                            <th>Status</th>

                            <th>Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        <% employees.forEach(function(employee,index){ %>

                            <tr>

                                <td>

                                    <%= index + 1 %>

                                </td>

                                <td>

                                    <%= employee.employeeId %>

                                </td>

                                <td>

                                    <%= employee.name %>

                                </td>

                                <td>

                                    <%= employee.email %>

                                </td>

                                <td>

                                    <%= employee.phone %>

                                </td>

                                <td>

                                    <%= employee.department %>

                                </td>

                                <td>

                                    <%= employee.designation %>

                                </td>

                                <td>

                                    <%= employee.status %>

                                </td>

                                <td>

                                    <a
                                        href="/hr/employees/edit/<%= employee._id %>"
                                        class="btn btn-warning"
                                    >

                                        Edit

                                    </a>

                                    <a
                                        href="/hr/employees/delete/<%= employee._id %>"
                                        class="btn btn-secondary"
                                        onclick="return confirm('Delete this employee?')"
                                    >

                                        Delete

                                    </a>

                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            <% } %>

        </div>

    </div>

</div>

<%- include("../partials/footer") %>