<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Employee Management System</title>

    <link rel="stylesheet"
          href="/css/index.css">

</head>

<body>

<div class="container">

    <div class="landing-card">

        <h1>

            Employee Management System

        </h1>

        <% if(!hrExists){ %>

            <p class="welcome">

                Welcome to Employee Management System

            </p>

            <div class="divider"></div>

            <h3>

                New to the system?

            </h3>

            <a href="/hr/setup"
               class="btn btn-primary">

                Create HR Account

            </a>

            <h3 class="login-title">

                Already have an HR Account?

            </h3>

            <a href="/hr/login"
               class="btn btn-secondary">

                HR Login

            </a>

        <% } else { %>

            <p class="welcome">

                Welcome Back

            </p>

            <div class="divider"></div>

            <h3>

                HR Account Already Exists

            </h3>

            <a href="/hr/login"
               class="btn btn-secondary">

                HR Login

            </a>

        <% } %>

    </div>

</div>

</body>

</html>